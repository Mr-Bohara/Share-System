rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /files/{fileId} {
      // Anyone can read file metadata for downloading and previewing
      allow read: if true;
      
      // Allow creation if size is under 500MB, filename is a string, and storagePath is a string.
      allow create: if request.resource.data.size <= 524288000 // Max 500MB
                    && request.resource.data.filename is string
                    && request.resource.data.storagePath is string;
      
      // Allow deletion.
      allow delete: if true;
    }
  }
}
