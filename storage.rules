rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /uploads/{fileId}/{fileName} {
      // Anyone can read/download files
      allow read: if true;
      
      // Allow upload if size is under 500MB
      allow create: if request.resource.size <= 524288000;
      
      // Allow deletion
      allow delete: if true;
    }
  }
}
